@inject Mas.Infrastructure.Common.ConnectionManager ConMan

@using System.Threading
@using BlazorDrawFBP.Renderers
@using Mas.Infrastructure.BlazorComponents
@inject IDialogService DialogService
@* @inject BlazorDispatcher Dispatcher *@

<div>
    <MudPaper Style="@CardStyle" Class="position-relative overflow-visible d-flex flex-column align-content-space-between"
              Elevation="0">
        @if (HasLifecycleError)
        {
            <MudTooltip Text="@Node.LifecycleError"
                        Delay="200"
                        Arrow="true">
                <MudIcon Class="absolute"
                         Style="right: -10px; top: -10px; z-index: 2;"
                         Icon="@Icons.Material.Filled.ErrorOutline"
                         Color="Color.Error"
                         Size="Size.Small" />
            </MudTooltip>
        }
        <MudGrid Justify="Justify.Center" Spacing="1">
            <MudItem xs="4">
                <MudPaper Class="d-flex justify-start mud-width-full pl-3 pt-3" Outlined="false"
                          Elevation="0">
                    <MudButton Color="@Color.Primary"
                               Disabled="@Node.IsLifecycleBusy"
                               StartIcon="@LifecycleButtonIcon"
                               OnClick="@HandleLifecycleAction">
                        @LifecycleButtonText
                    </MudButton>
                </MudPaper>
            </MudItem>
            <MudItem Class="align-content-end" xs="4">
                <MudPaper Class="d-flex justify-center mud-width-full pr-3 pt-3" Outlined="false"
                          Elevation="0">
                    <MudButton Color="@Color.Primary"
                               EndIcon="@Icons.Material.Filled.OpenInNew"
                               OnClick="@ShowDetails">
                        Large
                    </MudButton>
                </MudPaper>
            </MudItem>
            <MudItem Class="align-content-end" xs="4">
                <MudPaper Class="d-flex justify-end mud-width-full pr-3 pt-3" Outlined="false"
                          Elevation="0">
                    <MudButton Color="@Color.Primary"
                               OnClick="@Node.ResetViewContent"
                               EndIcon="@Icons.Material.Filled.Clear">
                        Clear
                    </MudButton>
                </MudPaper>
            </MudItem>
        </MudGrid>
        <MudGrid Class="flex-grow-1" Justify="Justify.Center" Spacing="0">
            <MudItem xs="12" Class="pl-3 pr-3 pt-2 pb-3">
                <Display WidthPx="@Node.DisplayWidthPx"
                         HeightPx="@Node.DisplayHeightPx"
                         EnableZoom="@(() => { Node.Editor?.Diagram.Options.Zoom.Enabled = true; })"
                         DisableZoom="@(() => { Node.Editor?.Diagram.Options.Zoom.Enabled = false; })">
                    @Node.ViewContent
                </Display>
            </MudItem>
        </MudGrid>
    </MudPaper>
    <MudText Style="@CardToolTipStyle" Typo="Typo.subtitle1" Align="Align.Center">
        @CardToolTipText
    </MudText>

    @foreach (var port in Node.Ports)
    {
        if (port is not CapnpFbpPortModel capnpPort) continue;

        <div @onmouseenter="@(() => CardToolTipText = Shared.MakePortToolTipText(capnpPort))"
             @onmouseleave="@(() => CardToolTipText = new MarkupString())">
            <CapnpFbpPortRenderer @key="capnpPort"
                                  Port="capnpPort"
                                  SocketColor="@FrameBorderColorValue" />
        </div>
    }
</div>

@code {
    [Parameter] public CapnpFbpViewComponentModel Node { get; set; } = null!;

    private string CardStyle =>
        $"height: {(Node.Size?.Height ?? 200)}px; width: {(Node.Size?.Width ?? 350)}px;{FrameWidth};{FrameColor}";
    private const string FrameWidth = "border-width: 1px";
    private string FrameBorderColorValue =>
        CapnpFbpPortColors.ResolveLifecycleFrameColor(Node.LifecycleState);
    private string FrameColor => $@"border-color: {FrameBorderColorValue}";
    private string LifecycleButtonText => Node.IsLifecycleBusy
        ? $"{Node.LifecycleLabel}..."
        : Node.LifecycleState switch
    {
        ComponentLifecycleState.Running => "Stop",
        ComponentLifecycleState.Failed => "Retry",
        ComponentLifecycleState.Closed => "Reconnect",
        _ => "Start",
    };
    private string LifecycleButtonIcon => Node.LifecycleState switch
    {
        ComponentLifecycleState.Running or ComponentLifecycleState.Stopping => Icons.Material.Filled.StopCircle,
        _ => Icons.Material.Filled.PlayCircle,
    };
    private bool HasLifecycleError =>
        Node.LifecycleState == ComponentLifecycleState.Failed
        && !string.IsNullOrWhiteSpace(Node.LifecycleError);

    private MarkupString CardToolTipText { get; set; }
    private string CardToolTipStyle => $"width: {(Node.Size?.Width ?? 350)}px;";

    protected override void OnInitialized()
    {
        // Node.Dispatcher = Dispatcher;
    }

    private async Task HandleLifecycleAction()
    {
        if (Node.CanStop)
            await Node.StopProcess(ConMan);
        else if (Node.CanStart)
            await Node.StartProcess(ConMan);

        StateHasChanged();
    }

    private async Task ShowDetails(MouseEventArgs e)
    {
        DialogOptions options = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

        var parameters = new DialogParameters
        {
            ["Content"] = Node.ViewContent,
            ["EnableZoom"] = () => { Node.Editor?.Diagram.Options.Zoom.Enabled = true; },
            ["DisableZoom"] = () => { Node.Editor?.Diagram.Options.Zoom.Enabled = false; },
        };

        await DialogService.ShowAsync<MarkupDisplayDialog>("View Content", parameters, options);
        StateHasChanged();
    }
}
